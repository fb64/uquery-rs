{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "install.uquery.dev" }],
      "destination": "https://uquery.dev/install.sh",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/install.sh",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}